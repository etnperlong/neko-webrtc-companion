# Example environment for neko-turn-refresh
NEKO_TURN_CRON=0 */6 * * *
CLOUDFLARE_TURN_KEY_ID=example-cloudflare-key-id
CLOUDFLARE_API_TOKEN=example-cloudflare-api-token
NEKO_CONFIG_PATH=/data/neko-config.yaml
HTTP_ADDR=:8080
CLOUDFLARE_TURN_TTL=86400
RUN_ON_START=true
DOCKER_CONTAINER_NAME_GLOB=neko-rooms-*
DOCKER_IMAGE_GLOB=ghcr.io/example/neko-*
DOCKER_LABEL_TRUE_KEY=turn.managed
DOCKER_RESTART_TIMEOUT=30s
