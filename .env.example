# Example environment for neko-turn-refresh
#
# This file works in two modes:
# 1. env-only: keep the runtime settings below enabled
# 2. YAML + env override: set CONFIG_FILE and leave any values you want to override here

# Optional YAML config file path.
# CONFIG_FILE=/config/config.yaml

# Required runtime settings.
NEKO_TURN_CRON=0 */6 * * *
CLOUDFLARE_TURN_KEY_ID=example-cloudflare-key-id
CLOUDFLARE_API_TOKEN=example-cloudflare-api-token
NEKO_CONFIG_PATH=/data/neko-config.yaml

# Optional runtime overrides.
HTTP_ADDR=:8080
CLOUDFLARE_TURN_TTL=86400
RUN_ON_START=true
DOCKER_CONTAINER_NAME_GLOB=neko-rooms-*
DOCKER_IMAGE_GLOB=ghcr.io/example/neko-*
DOCKER_LABEL_TRUE_KEY=turn.managed
DOCKER_RESTART_TIMEOUT=30s

# Logging.
LOG_FORMAT=text
LOG_LEVEL=info
LOG_COLOR=true
